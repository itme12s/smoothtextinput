{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "imes.smoothtextinput",
	"name": "Smooth TextInput",
	"version": "v1.0.0",
	"developer": "imes",
	"description": "Smooth text input animation.",
	"dependencies": {
		"geode.node-ids": ">=v1.23.3"
	},
	"settings": {
		"fade-in-duration": {
			"type": "float",
			"default": 0.15,
			"min": 0.0,
			"max": 1.0,
			"name": "Fade In Duration",
			"description": "Duration of character fade-in animation in seconds.",
			"control": {
				"slider": true,
				"slider-step": 0.01
			}
		},
		"fade-out-duration": {
			"type": "float",
			"default": 0.1,
			"min": 0.0,
			"max": 1.0,
			"name": "Fade Out Duration",
			"description": "Duration of character fade-out animation in seconds.",
			"control": {
				"slider": true,
				"slider-step": 0.01
			}
		}
	}
}